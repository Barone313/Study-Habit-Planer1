<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <TextView
        android:id="@+id/textViewHabitTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/textViewPlannedMinutes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Gewohnheitstitel" />

    <TextView
        android:id="@+id/textViewPlannedMinutes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textSize="16sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textViewHabitTitle"
        app:layout_constraintEnd_toStartOf="@+id/checkBoxDone"
        app:layout_constraintStart_toEndOf="@+id/textViewHabitTitle"
        tools:text="30 min" />

    <CheckBox
        android:id="@+id/checkBoxDone"
        android:layout_width="85dp"
        android:layout_height="77dp"
        android:width="16dp"
        android:height="48dp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textViewHabitTitle"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>